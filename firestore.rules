rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Read own profile only (AuthContext, CardContext)
      allow read: if request.auth != null && request.auth.uid == userId;

      // Client can only update cardNumber/cardId on own document (CardContext)
      // All other fields (phoneNumber, firstName, lastName, createdAt) are server-managed
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cardNumber', 'cardId'])
        && request.resource.data.cardNumber is string
        && request.resource.data.cardId is string;
    }

    // Server-only collections — Admin SDK bypasses rules, explicit deny for client access
    match /otpVerifications/{doc} {
      allow read, write: if false;
    }

    match /otpRateLimits/{doc} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
